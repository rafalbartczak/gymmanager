@page "/admin/scanner"
@implements IAsyncDisposable
<PageTitle>Skaner wejść</PageTitle>

@using System.Net.Http.Json
@using GymManager.Client.Services
@using GymManager.Client.Services.Auth
@inject ApiHttpClient Api
@inject TokenStore Tokens
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3 class="page-title">Skaner wejść (Admin)</h3>

@if (!isAdminChecked)
{
    <p>Sprawdzanie uprawnień...</p>
}
else if (!isAdmin)
{
    <div class="alert-error">Brak uprawnień.</div>
}
else
{
    <div style="display:flex; gap:20px; flex-wrap:wrap;">

        <!-- SKANER -->
        <div class="gym-card" style="flex:1; min-width:300px;">
            <h4 style="margin-top:0;">Skanuj kod klienta</h4>

            @if (!cameraStarted)
            {
                <button class="btn-primary-gym" style="width:100%; margin-bottom:15px;" @onclick="StartCamera">
                    📷 Uruchom kamerę
                </button>
            }
            else if (!cameraReady && !cameraError)
            {
                <p>Uruchamianie kamery...</p>
            }

            @if (cameraError)
            {
                <div class="alert-error">Nie udało się uruchomić kamery. Sprawdź uprawnienia.</div>
                <button class="btn-secondary-gym" style="margin-top:10px;" @onclick="StartCamera">
                    Spróbuj ponownie
                </button>
            }

            <div id="qr-reader-admin" style="@(cameraStarted && !cameraError ? "" : "display:none;") max-width:350px; margin:15px auto;"></div>

            <h5>Lub wpisz kod/email:</h5>
            <div class="gym-form">
                <div class="form-group">
                    <input type="text" @bind="manualCode" placeholder="ID użytkownika lub email" />
                </div>
                <button class="btn-primary-gym" style="width:100%;" disabled="@isBusy" @onclick="SubmitManualCode">
                    Weryfikuj i zarejestruj wejście
                </button>
            </div>
        </div>

        <!-- WYNIK WERYFIKACJI -->
        <div class="gym-card" style="flex:1; min-width:300px;">
            <h4 style="margin-top:0;">Wynik weryfikacji</h4>

            @if (!string.IsNullOrWhiteSpace(successMsg))
            {
                <div class="alert-success">@successMsg</div>
            }
            @if (!string.IsNullOrWhiteSpace(errorMsg))
            {
                <div class="alert-error">@errorMsg</div>
                @if (lastVerifyError == "NO_ACTIVE_PASS" && lastVerifiedUserId.HasValue)
                {
                    <button class="btn-secondary-gym" style="width:100%; margin-top:10px;" disabled="@isBusy" @onclick="ForceManualEntry">
                        Wpuść mimo to (rejestracja ręczna)
                    </button>
                }
            }
            @if (string.IsNullOrWhiteSpace(successMsg) && string.IsNullOrWhiteSpace(errorMsg))
            {
                <p style="opacity:0.7;">Zeskanuj kod QR klienta lub wpisz jego dane.</p>
            }

            <h5 style="margin-top:30px;">Ostatnie wejścia (dziś):</h5>
            @if (todayEntries is null)
            {
                <p>Ładowanie...</p>
            }
            else if (todayEntries.Count == 0)
            {
                <p>Brak wejść.</p>
            }
            else
            {
                <table class="gym-table">
                    <thead>
                        <tr>
                            <th>Godzina</th>
                            <th>Email</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in todayEntries.Take(10))
                        {
                            <tr>
                                <td>@e.EntryAt.ToLocalTime().ToString("HH:mm")</td>
                                <td>@e.UserEmail</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@code {
    bool isAdminChecked = false;
    bool isAdmin = false;
    bool cameraStarted = false;
    bool cameraReady = false;
    bool cameraError = false;
    bool isBusy = false;

    string manualCode = "";
    string? successMsg;
    string? errorMsg;
    string? lastVerifyError;
    Guid? lastVerifiedUserId;
    List<EntryDto>? todayEntries;

    DotNetObjectReference<AdminScanner>? objRef;

    protected override async Task OnInitializedAsync()
    {
        var access = await Tokens.GetAccessTokenAsync();
        if (string.IsNullOrWhiteSpace(access))
        {
            Nav.NavigateTo("/login");
            return;
        }

        var role = JwtHelper.GetRole(access);
        isAdmin = string.Equals(role, "admin", StringComparison.OrdinalIgnoreCase);
        isAdminChecked = true;

        if (!isAdmin) return;

        await LoadTodayEntries();
    }

    private async Task StartCamera()
    {
        cameraStarted = true;
        cameraError = false;
        cameraReady = false;
        StateHasChanged();

        // Poczekaj na renderowanie DOM
        await Task.Delay(300);

        try
        {
            objRef = DotNetObjectReference.Create(this);
            var result = await JS.InvokeAsync<bool>("startQrScanner", "qr-reader-admin", objRef);

            if (result)
            {
                cameraReady = true;
            }
            else
            {
                cameraError = true;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Camera error: {ex.Message}");
            cameraError = true;
        }

        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnQrScanned(string code)
    {
        // Zatrzymaj skaner żeby nie spamować
        try
        {
            await JS.InvokeVoidAsync("stopQrScanner");
            cameraStarted = false;
            cameraReady = false;
        }
        catch { }

        await ProcessCode(code);
    }

    private async Task SubmitManualCode()
    {
        if (string.IsNullOrWhiteSpace(manualCode)) return;
        await ProcessCode(manualCode.Trim());
    }

    private async Task ProcessCode(string code)
    {
        if (isBusy) return;
        isBusy = true;
        successMsg = null;
        errorMsg = null;
        lastVerifyError = null;
        lastVerifiedUserId = null;

        try
        {
            var res = await Api.Http.PostAsJsonAsync("entries/verify", new { UserCode = code });

            if (res.IsSuccessStatusCode)
            {
                var result = await res.Content.ReadFromJsonAsync<VerifyResponse>();
                if (result?.Success == true)
                {
                    successMsg = $"✅ Wejście zarejestrowane! ({result.UserEmail})";
                    manualCode = "";
                    await LoadTodayEntries();
                }
                else
                {
                    errorMsg = result?.Message ?? "Użytkownik nie ma aktywnego karnetu.";
                    lastVerifyError = result?.Error;
                    lastVerifiedUserId = result?.UserId;
                }
            }
            else if (res.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                errorMsg = "Nie znaleziono użytkownika.";
            }
            else if (res.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                errorMsg = "Nieprawidłowy kod.";
            }
            else
            {
                errorMsg = "Błąd rejestracji wejścia.";
            }
        }
        catch
        {
            errorMsg = "Błąd połączenia.";
        }
        finally
        {
            isBusy = false;
            StateHasChanged();
        }
    }

    private async Task ForceManualEntry()
    {
        if (isBusy || !lastVerifiedUserId.HasValue) return;
        isBusy = true;
        errorMsg = null;
        lastVerifyError = null;

        try
        {
            var res = await Api.Http.PostAsJsonAsync("entries/manual", new { UserId = lastVerifiedUserId.Value });

            if (res.IsSuccessStatusCode)
            {
                successMsg = "✅ Wejście zarejestrowane ręcznie (bez karnetu).";
                lastVerifiedUserId = null;
                manualCode = "";
                await LoadTodayEntries();
            }
            else
            {
                var body = await res.Content.ReadAsStringAsync();
                try
                {
                    var err = System.Text.Json.JsonSerializer.Deserialize<VerifyResponse>(body,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    errorMsg = err?.Message ?? "Nie udało się zarejestrować wejścia.";
                }
                catch
                {
                    errorMsg = "Nie udało się zarejestrować wejścia.";
                }
            }
        }
        catch
        {
            errorMsg = "Błąd połączenia.";
        }
        finally
        {
            isBusy = false;
            StateHasChanged();
        }
    }

    private async Task LoadTodayEntries()
    {
        try
        {
            var today = DateTime.UtcNow.Date.ToString("yyyy-MM-dd");
            todayEntries = await Api.Http.GetFromJsonAsync<List<EntryDto>>($"entries?from={today}&limit=50");
        }
        catch
        {
            todayEntries = new();
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("stopQrScanner");
        }
        catch { }

        objRef?.Dispose();
    }

    public class EntryDto
    {
        public Guid EntryId { get; set; }
        public string UserEmail { get; set; } = default!;
        public DateTime EntryAt { get; set; }
    }

    public class VerifyResponse
    {
        public bool Success { get; set; }
        public string? Error { get; set; }
        public string? Message { get; set; }
        public string? UserEmail { get; set; }
        public Guid? UserId { get; set; }
    }
}
