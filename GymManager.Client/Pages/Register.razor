    private void CloseModal() => showModal = false;

    private async Task DoRegister()
    {
        error = null;
        success = null;

        if (string.IsNullOrWhiteSpace(firstName))
        {
            error = "Podaj imię.";
            return;
        }

        if (string.IsNullOrWhiteSpace(lastName))
        {
            error = "Podaj nazwisko.";
            return;
        }

        if (string.IsNullOrWhiteSpace(email))
        {
            error = "Podaj adres email.";
            return;
        }

        if (!email.Contains("@") || !email.Contains(".") || email.Trim().Length < 5)
        {
            error = "Podaj poprawny adres email.";
            return;
        }

        if (string.IsNullOrWhiteSpace(password) || password.Length < 6)
        {
            error = "Hasło musi mieć minimum 6 znaków.";
            return;
        }

        if (!termsAccepted)
        {
            error = "Musisz zaakceptować regulamin.";
            return;
        }

        if (!privacyAccepted)
        {
            error = "Musisz zaakceptować politykę prywatności.";
            return;
        }

        isBusy = true;

        try
        {
            var request = new RegisterRequest(
                email.Trim(),
                password,
                firstName.Trim(),
                lastName.Trim(),
                termsAccepted,
                privacyAccepted,
                false // marketing consent
            );

            var response = await Auth.RegisterAsync(request);
            await Tokens.SetTokensAsync(response.AccessToken, response.RefreshToken);

            Nav.NavigateTo("/");
        }
        catch (HttpRequestException ex)
        {
            if (ex.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                error = "Użytkownik o podanym adresie email już istnieje.";
            }
            else
            {
                error = "Nie udało się zarejestrować. Spróbuj ponownie.";
            }
        }
        catch
        {
            error = "Wystąpił błąd. Spróbuj ponownie.";
        }
        finally
        {
            isBusy = false;
        }
    }
}
