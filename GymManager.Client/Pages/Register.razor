@page "/register"
<PageTitle>Rejestracja - GymManager</PageTitle>

@using GymManager.Client.Contracts
@using GymManager.Client.Services.Auth
@inject AuthApiClient Auth
@inject TokenStore Tokens
@inject NavigationManager Nav

<div class="gym-form">
    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="alert-error">@error</div>
    }
    @if (!string.IsNullOrWhiteSpace(success))
    {
        <div class="alert-success">@success</div>
    }

    <div class="form-row">
        <div class="form-group">
            <label>Imię</label>
            <input type="text" @bind="firstName" placeholder="Jan" />
        </div>
        <div class="form-group">
            <label>Nazwisko</label>
            <input type="text" @bind="lastName" placeholder="Kowalski" />
        </div>
    </div>

    <div class="form-group">
        <label>Email</label>
        <input type="email" @bind="email" placeholder="jan@example.com" />
    </div>

    <div class="form-group">
        <label>Hasło</label>
        <input type="password" @bind="password" placeholder="" />
    </div>

    <div class="checkbox-group">
        <input type="checkbox" id="terms" @bind="termsAccepted" />
        <label for="terms">
            Akceptuję
            <a href="javascript:void(0)" @onclick="ShowTerms" @onclick:preventDefault style="text-decoration:underline; cursor:pointer;">Regulamin serwisu</a>
            (wymagany)
        </label>
    </div>

    <div class="checkbox-group">
        <input type="checkbox" id="privacy" @bind="privacyAccepted" />
        <label for="privacy">
            Zapoznałem się z
            <a href="javascript:void(0)" @onclick="ShowPrivacy" @onclick:preventDefault style="text-decoration:underline; cursor:pointer;">Polityką Prywatności</a>
            (wymagany)
        </label>
    </div>

    <button class="btn-primary-gym" style="width:100%;" disabled="@isBusy" @onclick="DoRegister">
        @(isBusy ? "Rejestracja..." : "Zarejestruj się")
    </button>
</div>

<!-- MODAL REGULAMINU / POLITYKI PRYWATNOŚCI -->
@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="gym-card modal-content" @onclick:stopPropagation>
            <h3 style="margin-top:0;">@modalTitle</h3>
            <div style="line-height:1.7; opacity:0.85;">
                @((MarkupString)modalContent)
            </div>
            <div style="text-align:center; margin-top:20px;">
                <button class="btn-secondary-gym" @onclick="CloseModal">Zamknij</button>
            </div>
        </div>
    </div>
}

<style>
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.7);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        overflow-y: auto;
    }

    .modal-content {
        max-width: 600px;
        width: 100%;
        max-height: 85vh;
        overflow-y: auto;
        margin: auto;
    }
</style>

