@page "/my-qrcode"
<PageTitle>Mój kod QR</PageTitle>

@using System.Net.Http.Json
@using GymManager.Client.Services
@using GymManager.Client.Services.Auth
@using GymManager.Client.Contracts
@inject ApiHttpClient Api
@inject TokenStore Tokens
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3 class="page-title">Mój kod QR</h3>

@if (isLoading)
{
    <p>Ładowanie...</p>
}
else if (!hasActivePass)
{
    <div class="alert-warning">
        Nie posiadasz aktywnego karnetu. Kod QR jest dostępny tylko dla posiadaczy aktywnych karnetów.
    </div>
    <div style="margin-top:20px; text-align:center;">
        <a href="/passes/buy" class="btn-primary-gym">Kup karnet</a>
    </div>
}
else
{
    <div class="gym-card" style="text-align:center;">
        <p>Pokaż ten kod pracownikowi recepcji:</p>
        <div id="qr-code" style="display:inline-block; padding:15px; background:white; border-radius:8px; min-width:200px; min-height:200px;"></div>
        <p style="margin-top:15px; opacity:0.7;">
            Karnet: @activePassName<br />
            Ważny do: @activePassEndAt?.ToLocalTime().ToString("yyyy-MM-dd")
        </p>
    </div>
}

@code {
    bool isLoading = true;
    bool hasActivePass = false;
    bool qrGenerated = false;
    string? activePassName;
    DateTime? activePassEndAt;
    string? userId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var token = await Tokens.GetAccessTokenAsync();
            if (string.IsNullOrWhiteSpace(token))
            {
                Nav.NavigateTo("/login");
                return;
            }

            userId = JwtHelper.GetUserId(token);

            var passes = await Api.Http.GetFromJsonAsync<List<MyPassItem>>("passes/me");
            var now = DateTime.UtcNow;
            var activePass = passes?.FirstOrDefault(p => p.Status == "active" && p.EndAt > now);

            if (activePass is not null)
            {
                hasActivePass = true;
                activePassName = activePass.PassTypeName;
                activePassEndAt = activePass.EndAt;
            }
        }
        catch
        {
            Nav.NavigateTo("/login");
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Generuj QR tylko gdy: mamy aktywny karnet, mamy userId, jeszcze nie wygenerowaliśmy
        if (hasActivePass && !string.IsNullOrWhiteSpace(userId) && !qrGenerated)
        {
            qrGenerated = true;

            // Małe opóźnienie żeby DOM się wyrenderował
            await Task.Delay(100);

            try
            {
                await JS.InvokeVoidAsync("generateQrCode", "qr-code", userId);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"QR generation error: {ex.Message}");
            }
        }
    }
}
