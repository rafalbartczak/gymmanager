@page "/passes/buy"
<PageTitle>Kup karnet</PageTitle>

@using System.Net.Http.Json
@using GymManager.Client.Contracts
@using GymManager.Client.Services
@inject ApiHttpClient Api
@inject NavigationManager Nav

<h3 class="page-title">Kup karnet</h3>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert-success">@message</div>
}
@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert-error">@error</div>
}

@if (isLoading)
{
    <p>Ładowanie...</p>
}
else if (showGateway && pendingPayment is not null)
{
    <style>
        .back-button-container {
            display: none !important;
        }</style>
    <!-- SYMULACJA BRAMKI PŁATNOŚCI -->
    <div class="gym-card" style="max-width:500px; margin:0 auto; text-align:center; overflow:hidden;">
        <div style="background:linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); color:white; padding:25px; border-radius:12px; margin-bottom:20px;">
            <h4 style="margin:0 0 5px 0; opacity:0.7; font-size:0.9em;">BRAMKA PŁATNOŚCI</h4>
            <h3 style="margin:0;">MockPay</h3>
        </div>

        <div style="padding:10px 0;">
            <p style="opacity:0.7; margin-bottom:5px;">Karnet</p>
            <p style="font-weight:600; font-size:1.1em; margin-top:0;">@pendingPayment.PassTypeName</p>
        </div>

        <div style="padding:10px 0; border-top:1px solid rgba(128,128,128,0.2);">
            <p style="opacity:0.7; margin-bottom:5px;">Do zapłaty</p>
            <p style="font-weight:700; font-size:1.5em; margin-top:0;">@pendingPayment.Amount.ToString("F2") @pendingPayment.Currency</p>
        </div>

        <div style="padding:10px 0; border-top:1px solid rgba(128,128,128,0.2);">
            <p style="opacity:0.7; margin-bottom:5px;">Nr transakcji</p>
            <p style="font-size:0.85em; font-family:monospace; margin-top:0;">@pendingPayment.ProviderOrderId</p>
        </div>

        <div style="display:flex; gap:10px; margin-top:20px;">
            <button class="btn-primary-gym" style="flex:1; min-width:0; box-sizing:border-box;" disabled="@isBusy" @onclick="ConfirmPayment">
                @(isBusy ? "Przetwarzanie..." : "Zapłać")
            </button>
            <button class="btn-secondary-gym" style="flex:1; min-width:0; box-sizing:border-box;" disabled="@isBusy" @onclick="CancelPayment">
                Anuluj
            </button>
        </div>
    </div>
}
else if (hasActivePass)
{
    <div class="alert-success">
        <strong>Posiadasz aktywny karnet!</strong><br />
        Typ: @activePassName<br />
        Ważny do: @activePassEndAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
    </div>
    <p>Możesz kupić nowy karnet dopiero po wygaśnięciu obecnego.</p>
    <button class="btn-secondary-gym" @onclick="GoToMyPasses">Przejdź do moich karnetów</button>
}
else if (types is null || types.Count == 0)
{
    <p>Brak dostępnych karnetów.</p>
}
else
{
    @foreach (var t in types)
    {
        <div class="gym-card">
            <h4 style="margin-top:0;">@t.Name</h4>
            <p style="opacity:0.8;">@t.Description</p>
            <div style="margin:10px 0;">⏱️ Czas trwania: @t.DurationDays dni</div>
            <div style="margin:10px 0; font-size:1.2em; font-weight:600;">💰 @t.Price @t.Currency</div>
            <button class="btn-primary-gym" style="margin-top:10px;" disabled="@isBusy" @onclick="() => Buy(t.PassTypeId)">
                Kup teraz
            </button>
        </div>
    }
}

@code {
    List<PassTypeListItem>? types;
    List<MyPassItem>? myPasses;
    bool isLoading = true;
    bool isBusy = false;
    bool hasActivePass = false;
    bool showGateway = false;
    string? activePassName;
    DateTime? activePassEndAt;
    string? message;
    string? error;

    BuyPassResponse? pendingPayment;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var typesTask = Api.Http.GetFromJsonAsync<List<PassTypeListItem>>("passtypes");
            var myPassesTask = Api.Http.GetFromJsonAsync<List<MyPassItem>>("passes/me");

            await Task.WhenAll(typesTask, myPassesTask);

            types = typesTask.Result;
            myPasses = myPassesTask.Result;

            var now = DateTime.UtcNow;
            var activePass = myPasses?.FirstOrDefault(p => p.Status == "active" && p.EndAt > now);

            if (activePass is not null)
            {
                hasActivePass = true;
                activePassName = activePass.PassTypeName;
                activePassEndAt = activePass.EndAt;
            }
        }
        catch
        {
            Nav.NavigateTo("/login");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Buy(Guid passTypeId)
    {
        isBusy = true;
        message = null;
        error = null;

        try
        {
            var res = await Api.Http.PostAsJsonAsync("passes/buy", new BuyPassRequest(passTypeId));

            if (res.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                error = "Posiadasz już aktywny karnet.";
                hasActivePass = true;
                return;
            }

            if (!res.IsSuccessStatusCode)
            {
                error = "Błąd inicjalizacji płatności. Spróbuj ponownie.";
                return;
            }

            pendingPayment = await res.Content.ReadFromJsonAsync<BuyPassResponse>();
            showGateway = true;
        }
        catch
        {
            error = "Nie udało się rozpocząć płatności.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task ConfirmPayment()
    {
        if (pendingPayment is null) return;

        isBusy = true;
        error = null;

        try
        {
            var req = new ConfirmPaymentRequest(pendingPayment.PaymentId, pendingPayment.PassTypeId);
            var res = await Api.Http.PostAsJsonAsync("passes/confirm", req);

            if (!res.IsSuccessStatusCode)
            {
                error = "Błąd potwierdzenia płatności.";
                return;
            }

            var result = await res.Content.ReadFromJsonAsync<ConfirmPaymentResponse>();
            showGateway = false;
            pendingPayment = null;

            message = $"Płatność zakończona! Karnet ważny do {result!.EndAt.ToLocalTime():yyyy-MM-dd HH:mm}.";
            hasActivePass = true;
            activePassName = types?.FirstOrDefault(t => t.PassTypeId == req.PassTypeId)?.Name;
            activePassEndAt = result.EndAt;
        }
        catch
        {
            error = "Błąd połączenia z bramką płatności.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private void CancelPayment()
    {
        showGateway = false;
        pendingPayment = null;
        message = null;
        error = null;
    }

    private void GoToMyPasses() => Nav.NavigateTo("/passes/me");
}
